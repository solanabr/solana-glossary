{
  "name": "@stbr/solana-glossary-mcp",
  "version": "1.0.0",
  "description": "MCP Server for the Solana Glossary — Streamable HTTP transport",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node20 --clean",
