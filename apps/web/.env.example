# Absolute site URL (no trailing slash). Used for X share → flashcards link.
# Production: https://your-domain.com
BASE_URL=http://localhost:3000

# Optional: direct link to the VS Code Marketplace extension page (header nav).
# NEXT_PUBLIC_VSCODE_EXTENSION_URL=https://marketplace.visualstudio.com/items?itemName=...

# Show/hide MCP, CLI, and VS Code in home nav + hero + sitemap. Unset = show.
# Hide with: 0 | false | no | off
NEXT_PUBLIC_SHOW_NAV_MCP=true
NEXT_PUBLIC_SHOW_NAV_CLI=0
NEXT_PUBLIC_SHOW_NAV_VSCODE=0